{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile",
        "rootDirectory": "mobile"
    },
    "deploy": {
        "numReplicas": 1,
        "sleepApplication": false,
        "healthCheckPath": "/health",
        "healthCheckTimeout": 120
    }
}